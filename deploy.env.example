# Copy values into your .env before running deploy_stack.py
CFN_STACK_NAME=migrai-demo-stack
CFN_PARAM_VPC_ID=vpc-xxxxxxxx
CFN_PARAM_WEB_SUBNET_ID=subnet-xxxxxxxx
CFN_PARAM_KEY_PAIR_NAME=my-keypair
CFN_PARAM_ALLOWED_CIDR=10.0.0.0/16
CFN_PARAM_WEB_AMI_ID=ami-0c55b159cbfafe1f0
CFN_PARAM_DB_SUBNET_GROUP_NAME=my-db-subnet-group
CFN_PARAM_DB_USERNAME=postgresadmin
CFN_PARAM_DB_PASSWORD=replace-with-strong-password
CFN_PARAM_DB_INSTANCE_CLASS=db.t3.micro
