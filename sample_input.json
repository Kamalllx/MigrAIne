{
  "migration_id": "mig-20260401-template",
  "source": {
    "provider": "gcp",
    "region": "us-central1"
  },
  "target": {
    "provider": "aws",
    "region": "us-east-1"
  },
  "resources": [
    {
      "id": "gcp-vpc-main",
      "source_native_id": "projects/my-project/global/networks/default",
      "category": "network",
      "gcp_resource_type": "google_compute_network",
      "config": {
        "name": "default",
        "auto_create_subnets": false
      }
    },
    {
      "id": "gcp-subnet-app",
      "source_native_id": "projects/my-project/regions/us-central1/subnetworks/app-subnet",
      "category": "network",
      "gcp_resource_type": "google_compute_subnetwork",
      "depends_on": ["gcp-vpc-main"],
      "config": {
        "name": "app-subnet",
        "ip_cidr_range": "10.0.1.0/24",
        "region": "us-central1"
      }
    },
    {
      "id": "gcp-firewall-app",
      "source_native_id": "projects/my-project/global/firewalls/allow-app",
      "category": "network",
      "gcp_resource_type": "google_compute_firewall",
      "depends_on": ["gcp-vpc-main"],
      "config": {
        "name": "allow-app",
        "allow_http": true,
        "allow_https": true,
        "allow_internal": true
      }
    },
    {
      "id": "gcp-compute-api",
      "source_native_id": "projects/my-project/zones/us-central1-a/instances/api-server",
      "category": "compute",
      "gcp_resource_type": "google_compute_instance",
      "depends_on": ["gcp-subnet-app", "gcp-firewall-app"],
      "config": {
        "name": "api-server",
        "machine_type": "n2-standard-2",
        "zone": "us-central1-a",
        "boot_disk_size_gb": 50,
        "boot_disk_type": "pd-ssd"
      }
    },
    {
      "id": "gcp-storage-app",
      "source_native_id": "projects/my-project/buckets/app-data-prod",
      "category": "storage",
      "gcp_resource_type": "google_storage_bucket",
      "config": {
        "name": "app-data-prod",
        "location": "US",
        "storage_class": "STANDARD",
        "uniform_bucket_level_access": true,
        "versioning_enabled": true
      }
    },
    {
      "id": "gcp-storage-backups",
      "source_native_id": "projects/my-project/buckets/app-backups-prod",
      "category": "storage",
      "gcp_resource_type": "google_storage_bucket",
      "config": {
        "name": "app-backups-prod",
        "location": "US",
        "storage_class": "NEARLINE",
        "uniform_bucket_level_access": true,
        "versioning_enabled": true,
        "lifecycle_age_days": 90
      }
    },
    {
      "id": "gcp-sql-postgres",
      "source_native_id": "projects/my-project/instances/postgres-prod",
      "category": "database",
      "gcp_resource_type": "google_sql_database_instance",
      "depends_on": ["gcp-subnet-app"],
      "config": {
        "name": "postgres-prod",
        "database_version": "POSTGRES_15",
        "tier": "db-n1-standard-4",
        "region": "us-central1",
        "disk_type": "PD_SSD",
        "disk_size_gb": 200,
        "backup_enabled": true,
        "backup_days": 14,
        "require_ssl": true
      }
    },
    {
      "id": "gcp-function-processor",
      "category": "serverless",
      "gcp_resource_type": "google_cloudfunctions_function",
      "depends_on": ["gcp-pubsub-events"],
      "config": {
        "name": "process-order-events",
        "runtime": "python311",
        "available_memory_mb": 1024,
        "timeout_seconds": 60,
        "trigger": "pubsub"
      }
    },
    {
      "id": "gcp-pubsub-events",
      "source_native_id": "projects/my-project/topics/order-events",
      "category": "messaging",
      "gcp_resource_type": "google_pubsub_topic",
      "config": {
        "name": "order-events",
        "message_retention_duration": "604800s"
      }
    },
    {
      "id": "gcp-redis-cache",
      "source_native_id": "projects/my-project/locations/us-central1/instances/redis-prod",
      "category": "cache",
      "gcp_resource_type": "google_redis_instance",
      "depends_on": ["gcp-vpc-main"],
      "config": {
        "name": "redis-prod",
        "tier": "STANDARD_HA",
        "memory_size_gb": 5,
        "redis_version": "7.0",
        "region": "us-central1",
        "authorized_network": "default",
        "transit_encryption_mode": "SERVER_AUTHENTICATION"
      }
    },
    {
      "id": "gcp-pubsub-alerts",
      "source_native_id": "projects/my-project/topics/migration-alerts",
      "category": "messaging",
      "gcp_resource_type": "google_pubsub_topic",
      "config": {
        "name": "migration-alerts",
        "message_retention_duration": "86400s"
      }
    }
  ],
  "batches": [
    ["gcp-vpc-main"],
    ["gcp-subnet-app", "gcp-firewall-app"],
    ["gcp-storage-app", "gcp-storage-backups", "gcp-pubsub-events", "gcp-pubsub-alerts"],
    ["gcp-sql-postgres", "gcp-redis-cache"],
    ["gcp-compute-api", "gcp-function-processor"]
  ]
}